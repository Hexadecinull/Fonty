# =============================================================================
# Fonty .gitignore
# =============================================================================

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# Electron build output
desktop/dist/
desktop/node_modules/

# electron-builder cache
desktop/.cache/

# =============================================================================
# OS
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# =============================================================================
# Editors
# =============================================================================

# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (WebStorm, IDEA, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*.swn
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# =============================================================================
# Env / secrets (never commit these)
# =============================================================================

.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Apple signing certs (if stored locally during dev)
*.p12
*.cer
*.mobileprovision

# =============================================================================
# Misc
# =============================================================================

# Test output
coverage/

# Logs
logs/
*.log

# Temp files
tmp/
temp/

# Android Capacitor generated directories
android/www/
android/android/
android/node_modules/

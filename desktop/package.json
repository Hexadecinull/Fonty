{
  "name": "fonty",
  "version": "2.1.0",
  "description": "Font manager, inspector and converter with best-in-class FNT/AngelCode bitmap font support",
  "homepage": "https://github.com/Hexadecinull/Fonty",
  "main": "main.js",
  "author": {
    "name": "Fonty Contributors",
    "email": "noreply@fonty.app"
  },
  "license": "GPL-3.0",
  "scripts": {
    "start": "electron .",
    "build":       "electron-builder",
    "build:win":   "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac":   "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "io.fonty.app",
    "productName": "Fonty",
    "copyright": "Copyright (c) 2024 Fonty Contributors",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "index.html",
      "app.js",
      "app.css",
      "lib/fonty.js",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64", "ia32"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "compression": "lzma"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "maintainer": "Fonty Contributors <noreply@fonty.app>",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "deb": {
      "packageCategory": "utils",
      "depends": ["libnotify4", "libxtst6", "libnss3"]
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.utilities",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "window": { "width": 540, "height": 380 }
    }
  }
}
